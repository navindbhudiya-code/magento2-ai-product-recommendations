<?xml version="1.0" encoding="UTF-8"?>
<!--
/**
 * NavinDBhudiya ProductRecommendation
 *
 * Integration test suite (skeleton). See Test/Integration/README.md for how DB-backed
 * integration tests (Phase 1+) attach to Magento's integration framework. The current
 * SmokeTest is dependency-free so the harness stays green from Phase 0.
 *
 * @license MIT License
 */
-->
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="https://schema.phpunit.de/10.5/phpunit.xsd"
         colors="true"
         cacheDirectory=".phpunit.cache"
         beStrictAboutTestsThatDoNotTestAnything="false">
    <testsuites>
        <testsuite name="NavinDBhudiya_ProductRecommendation_Integration_Tests">
            <directory>./</directory>
        </testsuite>
    </testsuites>
    <php>
        <ini name="date.timezone" value="America/Los_Angeles"/>
    </php>
</phpunit>
